# === Application Configuration ===
APP_NAME=FlowingBot

# === Port Configuration ===
API_PORT=5000
FRONTEND_PORT=80

# === Backend Configuration ===
ASPNETCORE_ENVIRONMENT=Production

# === Database Configuration ===
# SQLite database path inside container (named volume will persist data)
DB_PATH=/app/data/FlowingBot.db

# === AI Configuration ===
# Ollama Model Name - set to your desired model (e.g., llama3.2:latest)
OLLAMA_MODEL_NAME=llama3.2:latest

# OpenAI Configuration (optional - leave empty if not using)
OPENAI_API_KEY=
OPENAI_MODEL_NAME=

# === Frontend Configuration ===
# API URL that frontend will use (must match API_PORT)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=FlowingBot
